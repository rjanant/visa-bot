# ── VFS Global credentials ───────────────────────────────────────────────────
# Your VFS Global account email and password
VFS_EMAIL=your_vfs_email@example.com
VFS_PASSWORD=your_vfs_password

# ── Gmail notification settings ──────────────────────────────────────────────
# The Gmail address you will send FROM
GMAIL_SENDER=your_gmail@gmail.com
# 16-character App Password (NOT your Gmail login password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PWD=xxxx xxxx xxxx xxxx

# The email address to send notifications TO (can be the same as GMAIL_SENDER)
NOTIFY_EMAIL=your_notify_email@example.com

# ── Proxy (required — Railway IPs are blocked by VFS) ────────────────────────
# Use a residential proxy. Webshare free tier works:
#   https://proxy.webshare.io  → Proxy List → copy any: host:port:user:pass
# Format: host:port:username:password
PROXY_SERVER=your_proxy_host:port
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

# ── Bot behaviour ─────────────────────────────────────────────────────────────
# How often to check for slots (in seconds). Default: 120 (2 minutes)
CHECK_INTERVAL_SECONDS=120
# Run browser without a visible window. Must be "true" on Railway.
HEADLESS=true
